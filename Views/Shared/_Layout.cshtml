<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    @Styles.Render("~/Content/css")
</head>
<body>
    <div id="side-menu" class="side-menu">
        <div class="side-menu-header">
            <i class="fa fa-times" id="menu-close"></i>
        </div>
        <div class="side-menu-content">
            @if (Registrar.Models.User.ConnectedUser != null)
            {
                <a href="@Url.Action("Index", "Students")"><i class="fa fa-user-graduate"></i> Étudiants</a>
                <a href="@Url.Action("Index", "Courses")"><i class="fa fa-book"></i> Cours</a>
                <a href="@Url.Action("Index", "Teachers")"><i class="fa fa-chalkboard-teacher"></i> Profs</a>
                <hr />
                <a href="@Url.Action("EditProfil", "Accounts")"><i class="fa fa-user-circle"></i> Mon profil</a>

                if (Registrar.Models.User.ConnectedUser.IsAdmin)
                {
                    <a href="@Url.Action("ManageUsers", "Accounts")"><i class="fa fa-users-cog"></i> Gérer les usagers</a>
                }
                <hr />
                <a href="@Url.Action("Logout", "Accounts")"><i class="fa fa-sign-out-alt"></i> Déconnexion</a>
            }
        </div>
    </div>
    <div class="page">
        @{
            Html.RenderPartial("_header");
        }

        <div id="contentPanel" class="content">
            <div id="mainContentPanel" class="main roundedBorder scrollable">
                @RenderBody()
            </div>
        </div>
        <div id="footerPanel" class="footerPanel">
            
            <span style="margin-left: 20px;">
                Session courante:
                <a href="@Url.Action("ChangeNextSession", "Accounts")" style="color: white; font-weight: bold; text-decoration: underline;">
                    @Registrar.Models.NextSession.Caption
                </a>
            </span>
        </div>

    </div>


    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>

    @Scripts.Render("~/bundles/validation")


    @if (Registrar.Models.User.ConnectedUser != null)
    {
        <script>
            $(document).ready(function () {
                // Initialise la session avec un timeout de 300 secondes (5 minutes)
                // Ajustez ce chiffre selon les directives de votre professeur
                newSession(300);

                // Réinitialise le compteur à chaque activité de la souris ou du clavier
                $(document).on('click keypress mousemove', function () {
                    if (typeof session !== 'undefined' && session) {
                        session.startCountdown();
                    }
                });
            });
        </script>
    }

    @RenderSection("scripts", required: false)

</body>
</html>