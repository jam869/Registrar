@{
    var connectedUser = Registrar.Models.User.ConnectedUser;
    bool userConnected = connectedUser != null;
    bool userIsAdmin = userConnected && connectedUser.IsAdmin;
    bool userCanWrite = userConnected && connectedUser.CanWrite;

    string controller = ViewContext.RouteData.Values["controller"].ToString().ToLower();
    string action = ViewContext.RouteData.Values["action"].ToString().ToLower();
    var routeId = ViewContext.RouteData.Values["id"];
}

<div class="headerMenu">
    <div class="header-left-part">
        <a href="@Url.Action("Index", "Students")" class="siteIcon" title="Collège Lionel-Groulx"></a>

        @if (userConnected)
        {
            if (action == "index")
            {
                <div class="header-nav-container">
                    <a href="@Url.Action("Index", "Students")" class="@(controller == "students" ? "active-nav" : "")">Étudiants</a>
                    <a href="@Url.Action("Index", "Courses")" class="@(controller == "courses" ? "active-nav" : "")">Cours</a>
                    <a href="@Url.Action("Index", "Teachers")" class="@(controller == "teachers" ? "active-nav" : "")">Profs</a>
                </div>
            }
            else
            {
                <div class="pageTitle">@ViewBag.Title</div>
            }
        }
    </div>

    <div class="header-right-part">
        @if (userConnected)
        {
            <div class="menu">
                @if (action == "index")
                {
                    if (userCanWrite)
                    {
                        <a href="/@controller/Create" class="cmdIcon fa fa-plus-circle" title="Ajouter..."></a>
                    }
                    <i class="cmdIcon fa fa-search" id="toggleSearchBtn" title="Recherche..."></i>
                }
                else if (action == "details")
                {
                    if (userCanWrite)
                    {
                        <a href="/@controller/Edit/@routeId" class="cmdIcon fa fa-edit" title="Modifier..."></a>
                        <a href="javascript:void(0)"
                           class="cmdIcon fa fa-trash-can"
                           title="Effacer"
                           onclick="bootboxConfirmDelete('/@controller/Delete/@routeId', '@controller')"
                           style="font-size: 24px; color: #0066cc; text-decoration:none;">
                        </a>
                    }
                    <a href="/@controller/Index" class="btn-close-square" title="Retour"><i class="fa fa-xmark"></i></a>
                }
                else if (action == "create" || action == "edit")
                {
                    <i class="cmdIcon fa fa-check" title="Sauvegarder" onclick="$('form').submit()"></i>
                    <a href="/@controller/Index" class="btn-close-square" title="Annuler"><i class="fa fa-xmark"></i></a>
                }
            </div>

            <div class="dropdown" style="display:inline-block;">
                <div data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer; padding-left: 10px;">
                    <i class="cmdIcon fa fa-bars" title="Menu"></i>
                </div>
                <div class="dropdown-menu dropdown-menu-end noselect" style="width: 280px;">
                    <a href="@Url.Action("EditProfil", "Accounts")" class="dropdown-item item-layout">
                        <i class="menuIcon fa fa-address-card"></i><span class="flexItem">Profil...</span>
                    </a>
                    <a href="@Url.Action("Logout", "Accounts")" class="dropdown-item item-layout">
                        <i class="menuIcon fa fa-sign-out-alt"></i><span class="flexItem">Déconnexion...</span>
                    </a>

                    @if (userIsAdmin)
                    {
                        <div class="dropdown-divider"></div>
                        <a href="@Url.Action("ManageUsers", "Accounts")" class="dropdown-item item-layout">
                            <i class="menuIcon fa fa-users-cog"></i><span class="flexItem">Gestion des usagers...</span>
                        </a>

                        <a href="@Url.Action("LoginsJournal", "Accounts")" class="dropdown-item item-layout">
                            <i class="menuIcon fa fa-history"></i><span class="flexItem">Historique de connexions</span>
                        </a>
                        <a href="@Url.Action("EventsJournal", "Accounts")" class="dropdown-item item-layout">
                            <i class="menuIcon fa fa-book"></i><span class="flexItem">Journal d'activités</span>
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>