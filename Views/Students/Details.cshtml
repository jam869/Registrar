@model Registrar.Models.Student
@{
    ViewBag.Title = "Étudiant - Détails";
}

<details id="student_info" open>
    <summary class="btn-details-summary">
        <i class="fa fa-graduation-cap"></i> @Model.FirstName @Model.LastName
    </summary>

    <div class="details-content-panel" style="padding: 20px;">
        <div class="detail-row">
            <i class="fa fa-barcode"></i> <strong>@Model.Code</strong>
        </div>
        <div class="detail-row">
            <i class="fa fa-phone"></i> @Model.Phone
        </div>
        <div class="detail-row">
            <i class="fa fa-envelope"></i> @Model.Email
        </div>
        <div class="detail-row">
            <i class="fa fa-birthday-cake"></i> Né le @Model.BirthDate.ToString("d MMMM yyyy")
        </div>
    </div>
</details>

<h3 style="margin-top:30px;">Inscriptions</h3>
<details id="inscriptions_details" open>
    <summary>Inscriptions</summary>
    <div style="padding: 15px;">
        @if (ViewBag.EnrolledCourses != null)
        {
            foreach (var course in (List<Registrar.Models.Course>)ViewBag.EnrolledCourses)
            {
                <div class="course-row" style="margin-bottom: 8px;">
                    <a href="@Url.Action("Details", "Courses", new { id = course.Id })" style="color: black; text-decoration: none;">
                        <span style="color: #0066cc; font-weight: bold;">[@course.Session] @course.Code</span> @course.Title
                    </a>
                </div>
            }
        }
    </div>
</details>