@model Registrar.Models.Student
@{
    ViewBag.Title = "Étudiant - Détails";
}

<div style="max-width: 900px; margin: auto;">
    <div id="studentInfoContainer">
        @{ Html.RenderAction("GetStudentInfo", new { id = Model.Id, forceRefresh = true }); }
    </div>

    <div id="inscriptionsContainer">
        @{ Html.RenderAction("GetStudentInscriptions", new { id = Model.Id, forceRefresh = true }); }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Rafraîchissement automatique toutes les 5 secondes
            new AutoRefreshedPanel(
                "studentInfoContainer",
                "@Url.Action("GetStudentInfo", new { id = Model.Id })",
                5
            );

            new AutoRefreshedPanel(
                "inscriptionsContainer",
                "@Url.Action("GetStudentInscriptions", new { id = Model.Id })",
                5
            );
        });
    </script>
}