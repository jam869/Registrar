@model IEnumerable<Registrar.Models.Student>


<div class="header-container">

    <div class="search-bar-container" style="margin-bottom: 15px;">

        <div id="searchPanel" style="display:none; margin-top:10px; background:#f9f9f9; padding:10px; border-radius:5px;">
            <input type="text" id="searchInput" class="form-control" placeholder="Rechercher par nom ou code..." style="display:inline-block; width:200px; margin-right:10px;" />
            <select id="yearFilter" class="form-control" style="display:inline-block; width:150px;">
                <option value="all">Toutes les années</option>
                <option value="2026">2026</option>
                <option value="2025">2025</option>
            </select>
        </div>
    </div>
</div>

<hr />

<div id="studentsListContainer">
    @{ Html.RenderAction("GetStudents", new { forceRefresh = true }); }
</div>
@section Scripts {
    <script>
       $(document).ready(function () {
    $("#toggleSearchBtn").click(function () {
        $("#searchPanel").slideToggle();
    });



            // Fonction de filtre et de surbrillance
            function applySearch() {
                let keyword = $("#searchInput").val().toLowerCase();
                let yearFilter = $("#yearFilter").val();

                // Parcourir chaque étudiant
                $(".StudentListLayout").each(function () {
                    let row = $(this);
                    let textToSearch = row.text().toLowerCase();
                    let parentDetails = row.closest('details');

                    // Sécurise la recherche de l'année au cas oů la balise summary n'est pas encore chargée
                    let summaryText = parentDetails.find('summary').text();
                    let cohorteYear = summaryText ? summaryText.replace('Cohorte ', '').trim() : "";

                    let matchKeyword = keyword === "" || textToSearch.indexOf(keyword) > -1;
                    let matchYear = yearFilter === "all" || cohorteYear === yearFilter;

                    if (matchKeyword && matchYear) {
                        row.show();
                        // Application de la surbrillance si un mot clé est tapé
                        if (keyword !== "") {
                            let regex = new RegExp("(" + keyword + ")", "gi");
                            row.find('.studentName, .studentCode').each(function () {
                                let originalText = $(this).text().replace(/(<mark>|<\/mark>)/igm, "");
                                $(this).html(originalText.replace(regex, "<mark>$1</mark>"));
                            });
                        } else {
                            // Retire la surbrillance si le champ est vide
                            row.find('.studentName, .studentCode').each(function () {
                                $(this).html($(this).text().replace(/(<mark>|<\/mark>)/igm, ""));
                            });
                        }
                    } else {
                        row.hide();
                    }
                });
            }

            // Déclencher la recherche quand l'usager tape ou change l'année
            $("#searchInput").on("keyup", applySearch);
            $("#yearFilter").on("change", applySearch);

            new AutoRefreshedPanel(
                "studentsListContainer",
                "@Url.Action("GetStudents")",
                5,
                function () {
                    // 1. Restaure l'état ouvert/fermé des cohortes
                    if (typeof RestoreDetailsState === "function") {
                        RestoreDetailsState();
                    }
                    // 2. Réapplique la recherche pour ne pas perdre le filtre en cours
                    applySearch();
                }
            );
        });
    </script>
   
}