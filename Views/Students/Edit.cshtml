@model Registrar.Models.Student

@{ ViewBag.Title = "Étudiant - Modification"; }

@using (Html.BeginForm())
{
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.Code)

    @Html.ValidationSummary(false, "Attention :", new { @class = "text-danger", style = "color:red; font-weight:bold; margin-bottom:15px;" })

    <details id="info_section" open>
        <summary>Informations - [@Model.Code]</summary>
        <div class="form-grid">
            <div>
                @Html.EditorFor(m => m.FirstName)
                @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger", style = "color:red; font-size:12px;" })
            </div>

            <div>
                @Html.EditorFor(m => m.LastName)
                @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger", style = "color:red; font-size:12px;" })
            </div>

            <div>
                @Html.TextBoxFor(m => m.BirthDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.BirthDate, "", new { @class = "text-danger", style = "color:red; font-size:12px;" })
            </div>

            <div>
                @Html.EditorFor(m => m.Email)
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger", style = "color:red; font-size:12px;" })
            </div>

            <div>
                @Html.EditorFor(m => m.Phone, new { htmlAttributes = new { @class = "form-control Phone", placeholder = "(000) 000-0000" } })
                @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger", style = "color:red; font-size:12px;" })
            </div>
        </div>
    </details>

    <details id="enrollement_section" open>
        <summary>Inscriptions: @Registrar.Models.NextSession.Caption</summary>

        @* On utilise l'outil EXACT du professeur *@
        @Helper.SelectionLists("SelectedCourses", (SelectList)ViewBag.Registrations, (SelectList)ViewBag.Courses)
    </details>

    <div style="margin-top: 20px;">
        <input type="submit" value="Enregistrer" class="btn btn-primary" />
        @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })
    </div>
}

@section Scripts {
    @* On utilise le script EXACT du professeur pour faire marcher ses listes *@
    <script src="~/Scripts/selections.js"></script>
}