@model Registrar.Models.Teacher
@{
    ViewBag.Title = "Professeur - Dťtails";
    double seniority = (Registrar.Models.NextSession.CurrentDate - Model.StartDate).TotalDays / 365.25;
}

<div style="max-width: 900px; margin: auto;">

    <details id="teacher_info" open>
        <summary class="btn-details-summary">
            <i class="fa fa-chalkboard-teacher"></i> @Model.FirstName @Model.LastName
        </summary>

        <div class="details-content-panel">
            <div style="display: flex; gap: 30px; align-items: flex-start; padding: 20px;">
                <div>
                    @Helper.Image(Model.Avatar, "UserMediumAvatar")
                </div>
                <div>
                    <div class="detail-row"><i class="fa fa-barcode"></i> <strong>@Model.Code</strong></div>
                    <div class="detail-row"><i class="fa fa-phone"></i> @Model.Phone</div>
                    <div class="detail-row"><i class="fa fa-calendar-alt"></i> Embauchť le @Model.StartDate.ToString("d MMMM yyyy")</div>
                    <div class="detail-row"><i class="fa fa-clock"></i> @seniority.ToString("F1") ans d'anciennetť</div>
                </div>
            </div>
        </div>
    </details>

    <h3 style="margin-top: 30px; font-weight: bold;">Allocations</h3>

    @if (ViewBag.GroupedAllocations != null && ((IEnumerable<IGrouping<int, Tuple<int, Registrar.Models.Course>>>)ViewBag.GroupedAllocations).Any())
    {
        @* LE CAST EXPLICITE ICI AUSSI *@
        foreach (var group in (IEnumerable<IGrouping<int, Tuple<int, Registrar.Models.Course>>>)ViewBag.GroupedAllocations)
        {
            <details open style="margin-bottom: 10px;">
                <summary class="btn-details-summary">@group.Key</summary>
                <div class="details-content-panel" style="padding: 15px;">
                    @foreach (var item in group)
                    {
                        var course = item.Item2;@* Item2 est notre Cours *@
                        <div class="course-row" style="margin-bottom: 10px;">
                            <a href="@Url.Action("Details", "Courses", new { id = course.Id })" style="color: black; text-decoration: none;">
                                <span style="color: #0066cc; font-weight: bold;">[@course.Session] @course.Code</span> @course.Title
                            </a>
                        </div>
                    }
                </div>
            </details>
        }
    }
    else
    {
        <p>Aucune allocation pour ce professeur.</p>
    }
</div>