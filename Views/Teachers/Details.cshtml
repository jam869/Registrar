@model Registrar.Models.Teacher
@{ ViewBag.Title = "Professeur - Dťtails"; }

<div class="details-header">@Model.FirstName @Model.LastName</div>

<div class="row">
    <div class="col-md-3">@Helper.Image(Model.Avatar, "UserMediumAvatar")</div>
    <div class="col-md-6">
        <div class="detail-row"><i class="fa fa-barcode"></i> <strong>@Model.Code</strong></div>
        <div class="detail-row"><i class="fa fa-phone"></i> @Model.Phone</div>
        <div class="detail-row"><i class="fa fa-calendar-check"></i> Embauchť le @Model.StartDate.ToString("yyyy-MM-dd")</div>
        <div class="detail-row">
            @{ double years = (DateTime.Now - Model.StartDate).TotalDays / 365.25; }
            <i class="fa fa-clock"></i> @Math.Round(years, 1) ans d'anciennetť
        </div>
    </div>
    <div class="col-md-3" style="text-align: right;">
        @if (Registrar.Models.User.ConnectedUser != null && Registrar.Models.User.ConnectedUser.CanWrite)
        {
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary"><i class="fa fa-edit"></i></a>
        }
        <a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-list"></i></a>
    </div>
</div>