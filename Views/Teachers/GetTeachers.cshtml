@model IEnumerable<Registrar.Models.Teacher>

@foreach (var item in Model)
{
    <div class="TeacherListLayout">
        <a href="@Url.Action("Details", new { id = item.Id })" style="display: flex; align-items: center; text-decoration: none; color: black;">

            @* Petit Avatar (CORRIGÉ ICI avec Helper.Image) *@
            <div style="margin-right: 15px;">
                @Helper.Image(item.Avatar, "UserSmallAvatar")
            </div>

            @* Code Bleu *@
            <span class="teacherCode" style="color: #0066cc; font-weight: bold; min-width: 110px;">@item.Code</span>

            @* Nom *@
            <div class="teacherName">@item.LastName @item.FirstName</div>

        </a>
    </div>
}