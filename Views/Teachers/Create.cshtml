@model Registrar.Models.Teacher

@{ ViewBag.Title = "Nouveau Professeur"; }

<h2>Ajouter un professeur</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-grid" style="display: flex; gap: 30px;">
        <div class="image-column">
            <label>Photo de profil</label>
            @Helper.ImageUploader("Avatar", Model.Avatar, "Cliquez pour ajouter une photo")
        </div>

        <div class="info-column" style="flex-grow: 1;">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

           

            <div class="form-group">
                <label>Prťnom</label>
                @Html.EditorFor(m => m.FirstName, new { htmlAttributes = new { @class = "form-control", placeholder = "Prťnom du prof" } })
            </div>

            <div class="form-group">
                <label>Nom de famille</label>
                @Html.EditorFor(m => m.LastName, new { htmlAttributes = new { @class = "form-control", placeholder = "Nom du prof" } })
            </div>

            <div class="form-group">
                <label>Tťlťphone professionnel</label>
                @Html.EditorFor(m => m.Phone, new { htmlAttributes = new { @class = "form-control", placeholder = "450-xxx-xxxx" } })
            </div>

            <div class="form-group">
                <label>Date d'embauche</label>
                @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger" })
            </div>

        </div>
    </div>
}

@section Scripts {
    <script src="~/Scripts/image-control.js"></script>
}