@{
    ViewBag.Title = "Cours";
}

<div id="searchPanel" style="display:none; margin-bottom:15px; background:#f9f9f9; padding:10px; border-radius:5px; border: 1px solid #ddd;">
    <input type="text" id="searchInput" class="form-control" placeholder="Rechercher par titre ou sigle..." style="max-width: 400px;" />
</div>

<div id="coursesListContainer">
    <img src="~/Content/UI-Images/Loading_icon.gif" style="display:block; margin:auto;" />
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Fait descendre la barre de recherche au clic sur la loupe
            $("#toggleSearchBtn").click(function () {
                $("#searchPanel").slideToggle(400, function() {
                    if (!$(this).is(':visible')) {
                        $("#searchInput").val("");
                        applySearch();
                    } else {
                        $("#searchInput").focus();
                    }
                });
            });

            // Fonction de filtre et de surbrillance
            function applySearch() {
                let keyword = $("#searchInput").val().toLowerCase();

                $(".CoursesListLayout").each(function () {
                    let row = $(this);
                    let textToSearch = row.text().toLowerCase();

                    if (keyword === "" || textToSearch.indexOf(keyword) > -1) {
                        row.show();
                        // Applique la surbrillance
                        if (keyword !== "") {
                            let regex = new RegExp("(" + keyword + ")", "gi");
                            row.find('.courseName, .courseCode').each(function () {
                                let originalText = $(this).text().replace(/(<mark>|<\/mark>)/igm, "");
                                $(this).html(originalText.replace(regex, "<mark>$1</mark>"));
                            });
                        } else {
                            // Enl�ve la surbrillance
                            row.find('.courseName, .courseCode').each(function () {
                                $(this).html($(this).text().replace(/(<mark>|<\/mark>)/igm, ""));
                            });
                        }
                    } else {
                        row.hide(); // Cache si �a ne correspond pas
                    }
                });
            }

            $("#searchInput").on("keyup", applySearch);

            // G�re le rafra�chissement automatique
            new AutoRefreshedPanel(
                "coursesListContainer",
                "@Url.Action("GetCourses")",
                5,
                function () {
                    // Restaure l'�tat des balises details (ouvert/ferm�)
                    if (typeof RestoreDetailsState === "function") {
                        RestoreDetailsState();
                    }
                    // R�applique le filtre pour ne pas perdre la recherche
                    applySearch();
                }
            );
        });
    </script>
}