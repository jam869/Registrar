@model Registrar.Models.Course

@{ ViewBag.Title = "Modifier le cours"; }

<h2>Modifier le cours : @Model.Code</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.Id)
    @Html.HiddenFor(model => model.Code) <div class="form-horizontal">
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })

        <div class="form-group">
            <label>Titre du cours</label>
            @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            <label>Session (1 ‡ 6)</label>
            @Html.EditorFor(model => model.Session, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => model.Session, "", new { @class = "text-danger" })
        </div>

        <div class="form-group" style="margin-top: 20px;">
            <input type="submit" value="Enregistrer" class="btn btn-primary" />
            @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })

            @* Optionnel : Bouton supprimer *@
            <a href="@Url.Action("Delete", new { id = Model.Id })"
               class="btn btn-danger"
               onclick="return confirm('Voulez-vous vraiment supprimer ce cours ?');">Supprimer</a>
        </div>
    </div>
}