@model Registrar.Models.Course
@{
    ViewBag.Title = "Cours - Détails";
}

<div style="max-width: 900px; margin: auto;">
    <div id="courseInfoContainer">
        @{ Html.RenderAction("GetCourseInfo", new { id = Model.Id, forceRefresh = true }); }
    </div>

    <div id="courseStudentsContainer">
        @{ Html.RenderAction("GetCourseStudents", new { id = Model.Id, forceRefresh = true }); }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            new AutoRefreshedPanel(
                "courseInfoContainer",
                "@Url.Action("GetCourseInfo", new { id = Model.Id })",
                5,
                function (data) {
                    if (data === null || data.trim() === "") {
                        bootbox.alert({
                            message: "Ce cours a été effacé ou n'est plus disponible.",
                            callback: function () {
                                window.location.href = "@Url.Action("Index")";
                            }
                        });
                    }
                }
            );

            new AutoRefreshedPanel(
                "courseStudentsContainer",
                "@Url.Action("GetCourseStudents", new { id = Model.Id })",
                5
            );
        });
    </script>
}